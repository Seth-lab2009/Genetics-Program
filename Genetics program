void intro() {
	cout <<"This program will show the chances of a child to either be a carrier or have colorblindness\n";// The first statement the user will see
}
void input(int& Dad, int& Mom, int& retry) {
	cout << "If the Dad isn't colorblind press 1 and if the Dad is colorblind press 2.\n";
