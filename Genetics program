}
void punnetsquare(int& Dad, int& Mom) { // The punnett squares start here.
	if (Dad == 1 & Mom == 1) {
		cout << "             X   |    Y\n";
		cout << "       --------------------\n";
		cout << "    X  |    XX   |   XY    |\n";
		cout << "----------------------------\n";
		cout << "    X  |    XX   |   XY    |\n";
		cout << "       --------------------\n";
		cout << "Genotypes: XbY = 0%, XbX = 0%, XbXb = 0% \n";
		cout << "Phenotypes: Colorblind = 0%, Not Colorblind = 100%\n";
	} else if (Dad == 1 & Mom == 2) {
		cout << "             X   |    Y\n";
		cout << "       --------------------\n";
		cout << "   Xb  |   XbX   |  XbY    |\n";
		cout << "----------------------------\n";
		cout << "   X   |   XX   |    XY    |\n";
		cout << "       --------------------\n";
		cout << "Genotypes: XbY = 25%, XbX = 25%, XbXb = 0% \n";
		cout << "Phenotypes: Colorblind = 0%, Not Colorblind = 100%\n";
	}	else if (Dad == 1 & Mom == 3) {
		cout << "             X   |    Y\n";
		cout << "       --------------------\n";
		cout << "   Xb  |   XbX   |  XbY    |\n";
		cout << "----------------------------\n";
		cout << "   Xb  |   XbX   |  XbY    |\n";
		cout << "       --------------------\n";
		cout << "Genotypes: XbY = 50%, XbX = 50%, XbXb = 0% \n";
		cout << "Phenotypes: Colorblind = 50%, Not Colorblind = 50%\n";
	} else if (Dad == 2 & Mom == 1) {
		cout << "            Xc   |    Y\n";
		cout << "       --------------------\n";
		cout << "    X  |    XbX   |   XY    |\n";
		cout << "----------------------------\n";
		cout << "    X  |    XbX   |   XY    |\n";
		cout << "       --------------------\n";
		cout << "Genotypes: XbY = 0%, XbX = 50%, XbXb = 0% \n";
		cout << "Phenotypes: Colorblind = 0%, Not Colorblind = 100%\n";
	} else if (Dad == 2 & Mom == 2) {
		cout << "            Xb   |    Y\n";
		cout << "       --------------------\n";
		cout << "   Xb |   XbXb   |   XbY   |\n";
		cout << "----------------------------\n";
		cout << "    X  |    XbX   |   XY    |\n";
		cout << "       --------------------\n";
		cout << "Genotypes: XcY = 25%, XcX = 25%, XcXc = 25% \n";
		cout << "Phenotypes: Colorblind = 50%, Not Colorblind = 50%\n";

	} else if (Dad == 2 & Mom == 3) {
		cout << "            Xb   |    Y\n";
		cout << "       --------------------\n";
		cout << "   Xb  |   XbXb   |   XbY   |\n";
		cout << "----------------------------\n";
		cout << "   Xb  |   XbXb   |   XbY   |\n";
		cout << "       --------------------\n";
		cout << "Genotypes: XbY = 25%, XbX = 25%, XbXb = 50% \n";
		cout << "Phenotypes: Colorblind = 100%, Not Colorblind = 0%\n";
	} else {
		cout << "Invalid inputs\n"; // if the user enters something that is not valid
	}
}
